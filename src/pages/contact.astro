---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout currentPath="/contact">
	<div>
		<p class="text-text-muted text-sm">
			<span class="text-accent">$</span> cat contact.txt
		</p>

		<div class="mt-6 text-text-muted select-none" aria-hidden="true">
			<span>───────────────────────────────────────</span>
		</div>

		<div class="mt-6 space-y-3 text-sm">
			<div class="flex gap-4">
				<span class="text-text-muted shrink-0 w-20">email</span>
				<span class="text-text-muted select-none">→</span>
				<a href="mailto:jake@mail.utoronto.ca" class="hover:text-accent transition-colors">
					jake@mail.utoronto.ca
				</a>
			</div>
			<div class="flex gap-4">
				<span class="text-text-muted shrink-0 w-20">github</span>
				<span class="text-text-muted select-none">→</span>
				<a href="https://github.com/jakemaly" class="hover:text-accent transition-colors" target="_blank" rel="noopener">
					github.com/jakemaly
				</a>
			</div>
			<div class="flex gap-4">
				<span class="text-text-muted shrink-0 w-20">linkedin</span>
				<span class="text-text-muted select-none">→</span>
				<a href="#" class="hover:text-accent transition-colors">
					linkedin.com/in/jakemaly
				</a>
			</div>
			<div class="flex gap-4">
				<span class="text-text-muted shrink-0 w-20">resume</span>
				<span class="text-text-muted select-none">→</span>
				<a href="https://jakemaly.github.io/resume/" class="hover:text-accent transition-colors" target="_blank" rel="noopener">
					jakemaly.github.io/resume
				</a>
			</div>

		</div>

		<div class="mt-10 text-text-muted select-none" aria-hidden="true">
			<span>───────────────────────────────────────</span>
		</div>

		<p class="mt-4 text-xs text-text-muted">
			<span class="text-accent">$</span> <span class="animate-pulse">█</span>
		</p>
	</div>
</BaseLayout>
