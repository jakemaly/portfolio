---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects', () => true);
---

<BaseLayout currentPath="/">
	<div class="min-h-[60vh] relative flex flex-col justify-center">
		<div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
			<iframe
				src="/heart.html"
				title="heart animation"
				class="absolute top-[-10%] right-0 translate-x-[30%] w-[640px] h-[480px] border-none bg-[#252526]"
				style="border: none; opacity: 0.4;"
				loading="lazy"
			></iframe>
		</div>
		<div class="relative z-10">
			<p class="text-sm text-text-muted/50 font-mono mb-2">
				$ whoami ?
			</p>
			<h1 class="font-heading text-[clamp(2.5rem,6vw,5rem)] font-medium tracking-tight text-text">
				jake maly
			</h1>
		<p class="font-body text-[clamp(0.9rem,2vw,1.15rem)] font-light leading-relaxed text-text-muted mt-4 max-w-lg">
			engineering, design, artificial intelligence.
			<!-- \n -->
			<br />
			student & ai research @ university of toronto
		</p>
		<div class="flex justify-start gap-4 mt-8">
			<a href="/work" class="font-body text-xl font-light text-text-muted hover:text-accent transition-colors underline underline-offset-4">
				view projects
			</a>
			<span class="text-text-muted/30">/</span>
			<a href="/contact" class="font-body text-xl font-light text-text-muted hover:text-accent transition-colors underline underline-offset-4">
				resume / contact
			</a>
		</div>
	</div>
	</div>

	<!-- Hero content section — edit the text below -->
	<!-- TIP: add images with <img src="/your-image.jpg" alt="..." /> -->
	<!-- TIP: images should be placed in /public/ at the project root -->
	<div class="mt-4 mb-20">
		<!-- ✏️ Terminal prompt decoration -->
		<p class="text-center text-sm text-text-muted/50 font-mono mb-2">
			$ ssh jake@portfolio
		</p>
		<!-- ✏️ Heading — centered independently -->
		<div class="text-center">
			<p class="font-heading text-[clamp(1.5rem,3.5vw,3rem)] font-medium tracking-tight text-text">
				education & experience
			</p>
		</div>
		<!-- ✏️ Body text — centered container, text left-aligned inside -->
		<div class="mt-4 mx-auto text-left max-w-lg">
			<p class="font-body text-[clamp(0.9rem,2vw,1.15rem)] font-light leading-relaxed text-text-muted">
			I'm currently working as an <em class="text-text/85 not-italic">Agentic AI Research Assistant</em> under the Dynamic Optimization & RL Lab in MIE. We're working to improve LLM evaluation for legal judgement.<br />
<br />I've helped build <em class="text-text/85 not-italic">5 freelance software projects</em> with Canadian clients across VC, SaaS, AI ed-Tech, and more. I build at hackathons, for design projects, and of course, for fun! <br /><br />
			I study <em class="text-text/85 not-italic">Engineering & Artificial Intelligence</em> at the
			<br />
			University of Toronto and am seeking <em class="text-text/85 not-italic">Summer 2027 internships!</em>
			</p>
		</div>

		<!-- ✏️ Add links, images, or more blocks below -->
		<!-- Example: <a href="/work" class="text-accent underline">View projects →</a> -->
		<!-- Example: <img src="/photo.jpg" alt="Me" class="mt-6 rounded-sm max-w-xs ml-auto block" /> -->
	</div>
</BaseLayout>
